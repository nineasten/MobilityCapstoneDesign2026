<launch>
  <arg name="reference_dir" default="$(env HOME)/capstonews/src/hloc_reference" />
  <arg name="ply_path" default="$(arg reference_dir)/debug_loop_closure/sfm_loop_closure_strict_seq10_loop75_20260522_170528/sparse_points_raw.ply" />
  <arg name="calibration_file" default="$(env HOME)/capstonews/src/calibration.json" />

  <arg name="frame_id" default="map" />
  <arg name="topic" default="/hloc_reference/points" />
  <arg name="occupancy_topic" default="/hloc_reference/xy_occupancy" />
  <arg name="bounds_topic" default="/hloc_reference/bounds" />
  <arg name="eraser_topic" default="/hloc_reference/erasers" />
  <arg name="rate" default="0.5" />
  <arg name="max_points" default="0" />
  <arg name="use_calibration" default="true" />
  <arg name="auto_floor_align" default="true" />
  <arg name="floor_fit_min_percentile" default="1.0" />
  <arg name="floor_fit_max_percentile" default="25.0" />
  <arg name="floor_fit_min_points" default="1000" />
  <arg name="floor_normal_min_z" default="0.5" />
  <arg name="publish_occupancy" default="true" />
  <arg name="publish_bounds" default="true" />
  <arg name="publish_erasers" default="false" />
  <arg name="grid_resolution" default="0.10" />
  <arg name="grid_padding" default="0.50" />
  <arg name="grid_min_z" default="0.0" />
  <arg name="grid_max_z" default="1.8" />
  <arg name="min_cell_points" default="1" />
  <arg name="wall_min_z_span" default="0.20" />
  <arg name="wall_z_bin_size" default="0.25" />
  <arg name="wall_min_z_bins" default="2" />
  <arg name="occupancy_closing_radius_cells" default="4" />
  <arg name="occupancy_min_component_cells" default="20" />
  <arg name="occupancy_inflation_radius_cells" default="2" />
  <arg name="cloud_min_z" default="0.0" />
  <arg name="cloud_max_z" default="1.8" />
  <arg name="edit_mode" default="true" />
  <arg name="edit_target" default="pointcloud" />
  <arg name="clicked_point_topic" default="/clicked_point" />
  <arg name="erase_mode" default="nearest" />
  <arg name="erase_radius" default="0.30" />
  <arg name="erase_nearest_max_distance" default="0.15" />
  <arg name="deleted_point_marker_size" default="0.08" />
  <arg name="eraser_file" default="$(arg reference_dir)/debug/manual_erasers.json" />
  <arg name="autosave_erasers" default="true" />
  <arg name="occupancy_edit_mode" default="free" />
  <arg name="occupancy_edit_radius" default="0.30" />
  <arg name="occupancy_edit_shape" default="square" />
  <arg name="occupancy_edit_file" default="$(arg reference_dir)/debug/manual_occupancy_edits.json" />
  <arg name="autosave_occupancy_edits" default="true" />

  <arg name="rviz" default="true" />
  <arg name="rviz_config" default="$(find hloc_localization)/rviz/hloc_reference_pointcloud.rviz" />

  <node
    pkg="hloc_localization"
    type="hloc_reference_pointcloud_publisher.py"
    name="hloc_reference_pointcloud_publisher"
    output="screen">
    <param name="reference_dir" value="$(arg reference_dir)" />
    <param name="ply_path" value="$(arg ply_path)" />
    <param name="calibration_file" value="$(arg calibration_file)" />
    <param name="frame_id" value="$(arg frame_id)" />
    <param name="topic" value="$(arg topic)" />
    <param name="occupancy_topic" value="$(arg occupancy_topic)" />
    <param name="bounds_topic" value="$(arg bounds_topic)" />
    <param name="eraser_topic" value="$(arg eraser_topic)" />
    <param name="rate" value="$(arg rate)" />
    <param name="max_points" value="$(arg max_points)" />
    <param name="use_calibration" value="$(arg use_calibration)" />
    <param name="auto_floor_align" value="$(arg auto_floor_align)" />
    <param name="floor_fit_min_percentile" value="$(arg floor_fit_min_percentile)" />
    <param name="floor_fit_max_percentile" value="$(arg floor_fit_max_percentile)" />
    <param name="floor_fit_min_points" value="$(arg floor_fit_min_points)" />
    <param name="floor_normal_min_z" value="$(arg floor_normal_min_z)" />
    <param name="publish_occupancy" value="$(arg publish_occupancy)" />
    <param name="publish_bounds" value="$(arg publish_bounds)" />
    <param name="publish_erasers" value="$(arg publish_erasers)" />
    <param name="grid_resolution" value="$(arg grid_resolution)" />
    <param name="grid_padding" value="$(arg grid_padding)" />
    <param name="grid_min_z" value="$(arg grid_min_z)" />
    <param name="grid_max_z" value="$(arg grid_max_z)" />
    <param name="min_cell_points" value="$(arg min_cell_points)" />
    <param name="wall_min_z_span" value="$(arg wall_min_z_span)" />
    <param name="wall_z_bin_size" value="$(arg wall_z_bin_size)" />
    <param name="wall_min_z_bins" value="$(arg wall_min_z_bins)" />
    <param name="occupancy_closing_radius_cells" value="$(arg occupancy_closing_radius_cells)" />
    <param name="occupancy_min_component_cells" value="$(arg occupancy_min_component_cells)" />
    <param name="occupancy_inflation_radius_cells" value="$(arg occupancy_inflation_radius_cells)" />
    <param name="cloud_min_z" value="$(arg cloud_min_z)" />
    <param name="cloud_max_z" value="$(arg cloud_max_z)" />
    <param name="edit_mode" value="$(arg edit_mode)" />
    <param name="edit_target" value="$(arg edit_target)" />
    <param name="clicked_point_topic" value="$(arg clicked_point_topic)" />
    <param name="erase_mode" value="$(arg erase_mode)" />
    <param name="erase_radius" value="$(arg erase_radius)" />
    <param name="erase_nearest_max_distance" value="$(arg erase_nearest_max_distance)" />
    <param name="deleted_point_marker_size" value="$(arg deleted_point_marker_size)" />
    <param name="eraser_file" value="$(arg eraser_file)" />
    <param name="autosave_erasers" value="$(arg autosave_erasers)" />
    <param name="occupancy_edit_mode" value="$(arg occupancy_edit_mode)" />
    <param name="occupancy_edit_radius" value="$(arg occupancy_edit_radius)" />
    <param name="occupancy_edit_shape" value="$(arg occupancy_edit_shape)" />
    <param name="occupancy_edit_file" value="$(arg occupancy_edit_file)" />
    <param name="autosave_occupancy_edits" value="$(arg autosave_occupancy_edits)" />
  </node>

  <node
    if="$(arg rviz)"
    pkg="rviz"
    type="rviz"
    name="hloc_reference_rviz"
    args="-d $(arg rviz_config)"
    output="screen" />
</launch>
