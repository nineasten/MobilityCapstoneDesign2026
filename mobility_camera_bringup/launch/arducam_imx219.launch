<launch>
  <arg name="video_device" default="/dev/v4l/by-id/usb-Arducam_Arducam_B0495__USB3_2.3MP__Arducam_202500915_0001-video-index0" />
  <arg name="image_width" default="960" />
  <arg name="image_height" default="600" />
  <arg name="framerate" default="10" />
  <arg name="pixel_format" default="yuyv" />
  <arg name="camera_name" default="arducam_imx219" />
  <arg name="camera_frame_id" default="arducam_imx219" />
  <arg name="camera_info_url" default="file://$(find mobility_camera_bringup)/config/arducam_camera_info.yaml" />
  <arg name="respawn" default="true" />
  <arg name="respawn_delay" default="2.0" />

  <node name="$(arg camera_name)"
        pkg="usb_cam"
        type="usb_cam_node"
        output="screen"
        respawn="$(arg respawn)"
        respawn_delay="$(arg respawn_delay)">
    <param name="video_device" value="$(arg video_device)" />
    <param name="image_width" value="$(arg image_width)" />
    <param name="image_height" value="$(arg image_height)" />
    <param name="pixel_format" value="$(arg pixel_format)" />
    <param name="camera_frame_id" value="$(arg camera_frame_id)" />
    <param name="camera_name" value="$(arg camera_name)" />
    <param name="camera_info_url" value="$(arg camera_info_url)" />
    <param name="framerate" value="$(arg framerate)" />
    <param name="io_method" value="mmap" />
  </node>
</launch>
