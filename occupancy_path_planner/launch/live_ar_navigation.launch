<launch>
  <param name="/use_sim_time" value="false" />

  <arg name="start_camera" default="true" />
  <arg name="configure_camera" default="true" />
  <arg name="start_localization" default="true" />
  <arg name="start_unity_endpoint" default="true" />
  <arg name="start_map_publisher" default="true" />
  <arg name="start_destination_selector" default="true" />

  <arg name="video_device" default="/dev/v4l/by-id/usb-Arducam_Arducam_B0495__USB3_2.3MP__Arducam_202500915_0001-video-index0" />
  <arg name="image_width" default="960" />
  <arg name="image_height" default="600" />
  <arg name="framerate" default="10" />
  <arg name="pixel_format" default="yuyv" />
  <arg name="camera_name" default="arducam_imx219" />
  <arg name="camera_frame_id" default="arducam_imx219" />
  <arg name="camera_info_url" default="file://$(find mobility_camera_bringup)/config/arducam_camera_info.yaml" />

  <arg name="auto_exposure" default="1" />
  <arg name="exposure_time_absolute" default="80" />
  <arg name="exposure_dynamic_framerate" default="0" />
  <arg name="gain" default="" />
  <arg name="white_balance_automatic" default="" />
  <arg name="white_balance_temperature" default="" />
  <arg name="power_line_frequency" default="" />

  <arg name="localization_device" default="auto" />
  <arg name="localization_min_interval" default="0.5" />
  <arg name="localization_top_k" default="5" />
  <arg name="localization_max_keypoints" default="512" />
  <arg name="localization_resize_max" default="800" />
  <arg name="localization_min_inliers" default="60" />
  <arg name="localization_blur_threshold" default="0.0" />

  <arg name="gui_on_start" default="true" />
  <arg name="rviz_on_select" default="true" />
  <arg name="clicked_point_mode" default="sequence" />

  <arg name="tcp_ip" default="0.0.0.0" />
  <arg name="tcp_port" default="10000" />

  <node
    if="$(arg configure_camera)"
    name="arducam_camera_config"
    pkg="mobility_camera_bringup"
    type="arducam_camera_config.py"
    output="screen">
    <param name="video_device" value="$(arg video_device)" />
    <param name="auto_exposure" value="$(arg auto_exposure)" />
    <param name="exposure_time_absolute" value="$(arg exposure_time_absolute)" />
    <param name="exposure_dynamic_framerate" value="$(arg exposure_dynamic_framerate)" />
    <param name="gain" value="$(arg gain)" />
    <param name="white_balance_automatic" value="$(arg white_balance_automatic)" />
    <param name="white_balance_temperature" value="$(arg white_balance_temperature)" />
    <param name="power_line_frequency" value="$(arg power_line_frequency)" />
  </node>

  <include
    if="$(arg start_camera)"
    file="$(find mobility_camera_bringup)/launch/arducam_imx219.launch">
    <arg name="video_device" value="$(arg video_device)" />
    <arg name="image_width" value="$(arg image_width)" />
    <arg name="image_height" value="$(arg image_height)" />
    <arg name="framerate" value="$(arg framerate)" />
    <arg name="pixel_format" value="$(arg pixel_format)" />
    <arg name="camera_name" value="$(arg camera_name)" />
    <arg name="camera_frame_id" value="$(arg camera_frame_id)" />
    <arg name="camera_info_url" value="$(arg camera_info_url)" />
  </include>

  <include file="$(find occupancy_path_planner)/launch/navigation_stack.launch">
    <arg name="start_map_publisher" value="$(arg start_map_publisher)" />
    <arg name="start_localization" value="$(arg start_localization)" />
    <arg name="start_destination_selector" value="$(arg start_destination_selector)" />
    <arg name="localization_image_topic" value="/$(arg camera_name)/image_raw" />
    <arg name="localization_camera_info_topic" value="/$(arg camera_name)/camera_info" />
    <arg name="localization_device" value="$(arg localization_device)" />
    <arg name="localization_min_interval" value="$(arg localization_min_interval)" />
    <arg name="localization_top_k" value="$(arg localization_top_k)" />
    <arg name="localization_max_keypoints" value="$(arg localization_max_keypoints)" />
    <arg name="localization_resize_max" value="$(arg localization_resize_max)" />
    <arg name="localization_min_inliers" value="$(arg localization_min_inliers)" />
    <arg name="localization_blur_threshold" value="$(arg localization_blur_threshold)" />
    <arg name="gui_on_start" value="$(arg gui_on_start)" />
    <arg name="rviz_on_select" value="$(arg rviz_on_select)" />
    <arg name="clicked_point_mode" value="$(arg clicked_point_mode)" />
  </include>

  <include
    if="$(arg start_unity_endpoint)"
    file="$(find ros_tcp_endpoint)/launch/endpoint.launch">
    <arg name="tcp_ip" value="$(arg tcp_ip)" />
    <arg name="tcp_port" value="$(arg tcp_port)" />
  </include>
</launch>
